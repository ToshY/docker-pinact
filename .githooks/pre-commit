#!/bin/sh

trap 'cleanup' INT

cleanup() {
  printf "\n⚠️ \033[33m%s\033[0m\n" "Aborted pre-commit hook"
  kill 0
  exit 1
}

run_command () {
  COMMAND_NAME=$1
  COMMAND_RUN=$2
  (
    OUTPUT=$(eval "$COMMAND_RUN" 2>&1)
    status_code=$?

    if [ $status_code -ne 0 ]; then
      printf "\r\033[K❌ %s \033[31m%s\033[0m\n" "$COMMAND_NAME" "failed" >&2
      echo "$OUTPUT" > "/tmp/${COMMAND_NAME}_pre-commit"
      exit 1
    else
      printf "\r\033[K✅ %s \033[32m%s\033[0m\n" "$COMMAND_NAME" "passed" >&2
    fi
  ) &
}

# Print + drain any failure files written by run_command. Sets HOOK_EXIT_CODE=1
# on any failure. Must be called *after* `wait`, otherwise the files don't
# exist yet and failures will be missed (and leak to the next run).
report_failures () {
  PATTERN=$1
  for OUTPUT_FILE in $PATTERN; do
    if [ ! -f "$OUTPUT_FILE" ]; then
      continue
    fi

    HOOK_EXIT_CODE=1
    printf "\n----------------\n❌ %s\n\n" "$(basename "$OUTPUT_FILE" '_pre-commit')"
    cat "$OUTPUT_FILE"
    rm "$OUTPUT_FILE"
  done
}

# Clean up any stale failure files left by a previously aborted run so they
# aren't misattributed to this commit.
rm -f /tmp/*_pre-commit 2>/dev/null || true

printf "🐚 \033[33m%s\033[0m\n\n" "Executing pre-commit hook..."

# GitHub Actions workflows
printf "\n======= %s =======\033[33m%s\033[0m\n" "GitHub Actions" >&2

WORKFLOW_STAGED_FILES=$(git diff --cached --name-only --diff-filter=AMR \
  | grep -E '^\.github/workflows/.+\.ya?ml$' \
  | xargs)
if [ "$WORKFLOW_STAGED_FILES" ]; then
  run_command "Actionlint" "docker run --rm -v \"$(pwd):/repo\" --workdir /repo rhysd/actionlint:1.7.12 -color $WORKFLOW_STAGED_FILES"
  run_command "Zizmor" "docker run --rm -v \"$(pwd):/repo\" --workdir /repo ghcr.io/zizmorcore/zizmor:1.25.2 --color=always $WORKFLOW_STAGED_FILES"
  if docker image inspect docker-pinact:local >/dev/null 2>&1; then
    run_command "Pinact" "docker run --rm -v \"$(pwd):/repo\" docker-pinact:local run --diff $WORKFLOW_STAGED_FILES"
  else
    printf "ℹ️ docker-pinact:local not found, skipping pinact (run 'task build' to enable)\n"
  fi

  wait
  report_failures "/tmp/Actionlint_pre-commit"
  report_failures "/tmp/Zizmor_pre-commit"
  report_failures "/tmp/Pinact_pre-commit"
else
    printf "ℹ️ No staged GitHub Actions workflow files\n"
fi

# Dockerfile
printf "\n======= %s =======\033[33m%s\033[0m\n" "Dockerfile" >&2

DOCKERFILE_STAGED_FILES=$(git diff --cached --name-only --diff-filter=AMR \
  | grep -E '^Dockerfile$' \
  | xargs)
if [ "$DOCKERFILE_STAGED_FILES" ]; then
  run_command "Hadolint" "docker run --rm -v \"$(pwd):/repo\" --workdir /repo ghcr.io/hadolint/hadolint:v2.14.0 hadolint $DOCKERFILE_STAGED_FILES"

  wait
  report_failures "/tmp/Hadolint_pre-commit"
else
  printf "ℹ️ No staged Dockerfile changes\n"
fi

printf "\n"
exit $HOOK_EXIT_CODE
